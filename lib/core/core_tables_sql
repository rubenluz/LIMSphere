const String coreTablesSQL = '''
-- Core tables for Culture Collection Manager

-- 1. app_meta: tracks database initialization
CREATE TABLE IF NOT EXISTS app_meta (
    initialized BOOLEAN DEFAULT false,
    version TEXT DEFAULT \'1.0\'
);

-- 2. users: lab staff
CREATE TABLE IF NOT EXISTS users (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    username TEXT NOT NULL UNIQUE,
    email TEXT,
    role TEXT NOT NULL,
    status TEXT DEFAULT \'pending\',
    created_at TIMESTAMP DEFAULT NOW()
);

-- 3. storage_locations: fridges, freezers, shelves, incubators
CREATE TABLE IF NOT EXISTS storage_locations (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL,
    type TEXT,
    description TEXT
);

-- 4. samples
CREATE TABLE IF NOT EXISTS samples (
    id              BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    number          INT,
    rebeca          TEXT,
    ccpi            TEXT,
    date            DATE,
    country         TEXT,
    archipelago     TEXT,
    island          TEXT,
    municipality    TEXT,
    local           TEXT,
    habitat_type    TEXT,
    habitat_1       TEXT,
    habitat_2       TEXT,
    habitat_3       TEXT,
    method          TEXT,
    photos          TEXT,
    gps             TEXT,
    temperature     NUMERIC,
    ph              NUMERIC,
    conductivity    NUMERIC,
    oxygen          NUMERIC,
    salinity        NUMERIC,
    radiation       NUMERIC,
    responsible     TEXT,
    observations    TEXT,
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 5. strains: main microalgae/cyanobacteria strains
CREATE TABLE IF NOT EXISTS strains (
    id                      BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    sample_id               BIGINT REFERENCES samples(id) ON DELETE SET NULL,

    -- Identity
    code                    TEXT UNIQUE,
    origin                  TEXT,
    status                  TEXT,
    toxins                  TEXT,
    situation               TEXT,
    last_checked            DATE,
    public                  TEXT,
    private_collection      TEXT,
    type_strain             TEXT,

    -- Taxonomy
    empire                  TEXT,
    class_name              TEXT,
    order_name              TEXT,
    family                  TEXT,
    genus                   TEXT,
    species                 TEXT,
    scientific_name         TEXT,
    authority               TEXT,
    old_identification      TEXT,
    photo                   TEXT,
    public_photo            TEXT,
    taxonomist              TEXT,
    other_names             TEXT,

    -- Ruy Telles Palhinha collection
    rtp_code                TEXT,
    rtp_status              TEXT,

    -- Culture maintenance
    last_transfer           DATE,
    time_days               INT,
    next_transfer           DATE,
    medium                  TEXT,
    room                    TEXT,
    isolation_responsible   TEXT,
    isolation_date          DATE,
    deposit_date            DATE,

    -- Molecular — prokaryotes
    seq_16s_bp              INT,
    its                     TEXT,
    its_bands               TEXT,
    cloned_gel              TEXT,
    genbank_16s_its         TEXT,
    genbank_status          TEXT,
    genome_pct              NUMERIC,
    genome_cont             INT,
    genome_16s              TEXT,
    gca_accession           TEXT,

    -- Molecular — eukaryotes
    seq_18s_bp              INT,
    genbank_18s             TEXT,
    its2_bp                 INT,
    genbank_its2            TEXT,
    rbcl_bp                 INT,
    genbank_rbcl            TEXT,

    -- Other
    publications            TEXT,
    qrcode                  TEXT,

    created_at              TIMESTAMP DEFAULT NOW()
);

-- Indexes for performance
CREATE INDEX IF NOT EXISTS idx_strains_sample_id ON strains(sample_id);
CREATE INDEX IF NOT EXISTS idx_strains_code      ON strains(code);
CREATE INDEX IF NOT EXISTS idx_samples_rebeca    ON samples(rebeca);
CREATE INDEX IF NOT EXISTS idx_samples_ccpi      ON samples(ccpi);

-- 6. reagents
CREATE TABLE IF NOT EXISTS reagents (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL,
    quantity TEXT,
    storage_location_id BIGINT REFERENCES storage_locations(id),
    created_at TIMESTAMP DEFAULT NOW()
);

-- 7. zebrafish_facility
CREATE TABLE IF NOT EXISTS zebrafish_facility (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    tank_name TEXT NOT NULL,
    capacity INT,
    notes TEXT
);

-- 8. equipment
CREATE TABLE IF NOT EXISTS equipment (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name TEXT NOT NULL,
    type TEXT,
    location TEXT,
    notes TEXT
);

-- 9. reservations
CREATE TABLE IF NOT EXISTS reservations (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    resource_type TEXT NOT NULL,
    resource_id BIGINT NOT NULL,
    user_id BIGINT REFERENCES users(id),
    start_time TIMESTAMP,
    end_time TIMESTAMP,
    purpose TEXT
);

-- 10. orders
CREATE TABLE IF NOT EXISTS orders (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    type TEXT NOT NULL,
    requester_id BIGINT REFERENCES users(id),
    status TEXT DEFAULT \'pending\',
    date_created TIMESTAMP DEFAULT NOW(),
    notes TEXT
);

-- 11. audit_log
CREATE TABLE IF NOT EXISTS audit_log (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    table_name TEXT NOT NULL,
    record_id BIGINT,
    action TEXT NOT NULL,
    user_id BIGINT REFERENCES users(id),
    timestamp TIMESTAMP DEFAULT NOW(),
    details TEXT
);

-- 12. protocols
CREATE TABLE IF NOT EXISTS protocols (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    created_by BIGINT REFERENCES users(id),
    created_at TIMESTAMP DEFAULT NOW()
);

-- Seed app_meta
INSERT INTO app_meta (initialized, version)
VALUES (true, \'1.0\')
ON CONFLICT DO NOTHING;
''';